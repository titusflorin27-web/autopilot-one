NODE_ENV=production
DATABASE_URL=postgresql://autopilot:replace-me@postgres:5432/autopilot?schema=public
REDIS_URL=redis://redis:6379
API_PORT=4000
API_CORS_ORIGINS=https://app.autopilot-one.com
JWT_ACCESS_SECRET=replace-with-long-random-value
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AI_GATEWAY_PROVIDER=openai
AI_GATEWAY_MODEL=gpt-4o-mini
AI_GATEWAY_BASE_URL=https://api.openai.com/v1
AI_GATEWAY_API_KEY=
PUBLIC_WIDGET_TOKEN=
PUBLIC_WIDGET_ALLOWED_ORIGINS=https://customer-site.example
PUBLIC_WIDGET_RATE_LIMIT_MAX=20
PUBLIC_WIDGET_RATE_LIMIT_WINDOW_SECONDS=60

# Public application URLs.
PUBLIC_APP_URL="https://app.autopilot-one.com"
PUBLIC_API_URL="https://api.autopilot-one.com"

# Demo request email notifications.
# Configure these only in server env files. Do not commit real API keys.
RESEND_API_KEY=""
DEMO_REQUEST_NOTIFICATION_TO=""
DEMO_REQUEST_NOTIFICATION_FROM=""

# Stripe billing integration.
# Use real values only in server env files, never in source control.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""
