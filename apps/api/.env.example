DATABASE_URL="postgresql://autopilot:autopilot@localhost:5432/autopilot?schema=public"
REDIS_URL="redis://localhost:6379"
API_PORT=4000
JWT_ACCESS_SECRET="change-me-local-access-secret"
JWT_ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Optional AI Gateway provider configuration.
# Without an API key, Reception AI automatically uses deterministic fallback mode.
AI_GATEWAY_PROVIDER="openai"
AI_GATEWAY_MODEL="gpt-4o-mini"
AI_GATEWAY_BASE_URL="https://api.openai.com/v1"
AI_GATEWAY_API_KEY=""
