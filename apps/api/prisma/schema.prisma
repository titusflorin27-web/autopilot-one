generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum EventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum KnowledgeSourceType {
  TXT
  PDF
  DOCX
  WEBSITE
}

enum KnowledgeSourceStatus {
  UPLOADED
  INDEXED
  FAILED
}

enum ConversationStatus {
  OPEN
  WAITING_FOR_HUMAN
  CLOSED
}

enum MessageSender {
  CUSTOMER
  AI
  HUMAN
  SYSTEM
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum WidgetPosition {
  LEFT
  RIGHT
}

enum WidgetEventType {
  CONFIG_LOADED
  LOADED
  OPENED
  MESSAGE_SENT
  MESSAGE_RECEIVED
  ERROR
}

model Organization {
  id                   String                  @id @default(cuid())
  name                 String
  slug                 String                  @unique
  industry             String?
  website              String?
  country              String?
  language             String                  @default("en")
  timezone             String                  @default("UTC")
  status               OrganizationStatus      @default(ACTIVE)
  businessDna          Json?
  widgetEnabled        Boolean                 @default(true)
  widgetTitle          String                  @default("Reception AI")
  widgetPrimaryColor   String                  @default("#8ee6c9")
  widgetPosition       WidgetPosition          @default(RIGHT)
  widgetToken          String?
  widgetAllowedOrigins String[]                @default([])
  memberships          Membership[]
  events               Event[]
  widgetEvents         WidgetEvent[]
  knowledgeSources     KnowledgeSource[]
  knowledgeChunks      KnowledgeChunk[]
  conversations        ReceptionConversation[]
  leads                Lead[]
  tasks                Task[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String?
  lastName      String?
  passwordHash  String
  memberships   Membership[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  payload        Json
  status         EventStatus  @default(PENDING)
  createdAt      DateTime     @default(now())
  processedAt    DateTime?
}

model WidgetEvent {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           WidgetEventType
  visitorId      String?
  conversationId String?
  websiteUrl     String?
  origin         String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([type])
  @@index([visitorId])
  @@index([createdAt])
}

model KnowledgeSource {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           KnowledgeSourceType
  status         KnowledgeSourceStatus @default(UPLOADED)
  title          String
  url            String?
  fileName       String?
  mimeType       String?
  contentHash    String?
  error          String?
  chunks         KnowledgeChunk[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([status])
}

model KnowledgeChunk {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceId       String
  source         KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunkIndex     Int
  content        String
  tokenCount     Int
  createdAt      DateTime        @default(now())

  @@unique([sourceId, chunkIndex])
  @@index([organizationId])
  @@index([sourceId])
}

model ReceptionConversation {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerName     String?
  customerEmail    String?
  channel          String             @default("web")
  status           ConversationStatus @default(OPEN)
  escalationReason String?
  internalNote     String?
  closedAt         DateTime?
  leadId           String?
  lead             Lead?              @relation(fields: [leadId], references: [id])
  messages         ReceptionMessage[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId])
  @@index([status])
}

model ReceptionMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   ReceptionConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         MessageSender
  content        String
  metadata       Json?
  createdAt      DateTime              @default(now())

  @@index([conversationId])
  @@index([sender])
}

model Lead {
  id              String                  @id @default(cuid())
  organizationId  String
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String?
  email           String?
  summary         String
  score           Int                     @default(0)
  status          LeadStatus              @default(NEW)
  ownerNote       String?
  lastContactedAt DateTime?
  conversations   ReceptionConversation[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([organizationId])
  @@index([status])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  ownerNote      String?
  completedAt    DateTime?
  dueAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([priority])
}
