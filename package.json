{
  "name": "autopilot-one",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @autopilot/web --filter @autopilot/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @autopilot/api prisma:generate",
    "db:migrate": "pnpm --filter @autopilot/api prisma:migrate"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
